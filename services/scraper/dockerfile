FROM python:3.12-alpine
WORKDIR /app

COPY --from=ghcr.io/astral-sh/uv:0.6.6 /uv /usr/local/bin/uv

RUN adduser -D scraper && chown -R scraper /app
USER scraper

COPY --chown=scraper pyproject.toml uv.lock ./
COPY --chown=scraper services/scraper/pyproject.toml ./services/scraper/pyproject.toml
COPY --chown=scraper packages/shared/ ./packages/shared/
RUN uv sync --frozen --no-dev --package scraper

COPY --chown=scraper services/scraper/ ./services/scraper/

CMD ["uv", "run", "--directory", "services/scraper", "main.py"]